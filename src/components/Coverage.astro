---
import { site, waLink } from "../config/site";
import Icon from "./Icon.astro";

const mapsQuery = encodeURIComponent(`${site.hq}, ${site.region}, Chile`);
const mapsEmbedSrc = `https://www.google.com/maps?q=${mapsQuery}&z=12&output=embed`;
const mapsLink = `https://www.google.com/maps/search/?api=1&query=${mapsQuery}`;
---

<section id="cobertura" class="bg-[color:var(--color-navy)] py-16 lg:py-24">
  <div class="max-w-[1200px] mx-auto px-5 lg:px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
      <div data-reveal>
        <p class="font-semibold text-sm uppercase tracking-[0.08em] text-[color:var(--color-yellow)] mb-3">
          Dónde operamos
        </p>
        <h2 class="font-display font-extrabold uppercase text-white text-[1.875rem] leading-[1.1] lg:text-5xl lg:leading-[1.05] tracking-tight mb-5">
          Toda la Región de Ñuble, las 24 horas
        </h2>
        <p class="text-[color:var(--color-chrome)] text-[17px] leading-relaxed mb-6">
          Con base en {site.hq}, operamos en Chillán, Chillán Viejo, Bulnes y comunas
          vecinas, además de toda la Ruta 5 Sur a su paso por Ñuble. Donde estés varado, vamos.
        </p>

        <div class="flex flex-wrap gap-2 mb-8">
          {
            site.comunas.map((comuna) => (
              <span class="inline-flex items-center rounded-full bg-[color:var(--color-blue)] border border-transparent hover:border-[color:var(--color-yellow)] text-white text-sm font-semibold px-3.5 py-1.5 transition-colors">
                {comuna}
              </span>
            ))
          }
        </div>

        <div class="flex items-center gap-3 mb-8">
          <Icon name="clock" class="w-6 h-6 text-[color:var(--color-yellow)]" />
          <span class="text-white font-semibold">Disponibles las 24 horas, los 7 días.</span>
        </div>

        <div class="flex flex-col sm:flex-row gap-3">
          <a
            href={waLink()}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center justify-center gap-2 h-12 px-6 rounded-full bg-[color:var(--color-wa)] text-[color:var(--color-ink)] font-bold text-sm shadow-[var(--shadow-cta)] hover:bg-[color:var(--color-wa-dark)] transition-colors"
          >
            <Icon name="whatsapp" class="w-4 h-4" />
            WhatsApp
          </a>
          <a
            href={site.phoneHref}
            class="inline-flex items-center justify-center gap-2 h-12 px-6 rounded-full border-2 border-white text-white font-bold text-sm hover:bg-white hover:text-[color:var(--color-navy)] transition-colors"
          >
            <Icon name="phone-call" class="w-4 h-4" />
            Llamar
          </a>
        </div>
      </div>

      <div class="relative rounded-2xl overflow-hidden aspect-[4/3] lg:aspect-square border border-[color:var(--color-chrome)]/15" data-reveal>
        <iframe
          src={mapsEmbedSrc}
          title={`Ubicación de ${site.name} en ${site.hq}, ${site.region}`}
          class="absolute inset-0 w-full h-full grayscale-[15%] contrast-[1.05]"
          style="border:0;"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>

        <div
          class="absolute inset-x-0 bottom-0 pointer-events-none"
          style="background: linear-gradient(0deg, rgba(10,42,94,.95) 10%, rgba(10,42,94,.7) 55%, transparent 100%);"
        >
          <div class="p-6 pt-16 pointer-events-auto">
            <p class="font-display font-extrabold uppercase text-white text-xl tracking-tight mb-1">
              Base en {site.hq}
            </p>
            <p class="text-[color:var(--color-chrome)] text-sm mb-3">
              {site.travelNote}
            </p>
            <a
              href={mapsLink}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-1.5 text-[color:var(--color-yellow)] font-bold text-sm hover:underline"
            >
              <Icon name="map-pin" class="w-4 h-4" />
              Ver en Google Maps
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
