---
import { Image } from "astro:assets";
import { site, waLink, withBase } from "../config/site";
import Icon from "./Icon.astro";
import tarjeta from "../assets/tarjeta-contacto.jpg";
---

<section id="contacto" class="bg-[#111111] relative">
  <div class="hazard-stripe"></div>
  <div class="max-w-[1200px] mx-auto px-5 lg:px-6 py-16 lg:py-24">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
      <div data-reveal>
        <h2 class="font-display font-extrabold uppercase text-white text-[1.875rem] leading-[1.1] lg:text-5xl lg:leading-[1.05] tracking-tight mb-4">
          ¿Lo necesitas ahora? Escríbenos.
        </h2>
        <p class="text-[color:var(--color-chrome)] text-[17px] leading-relaxed mb-8">
          Estamos listos para salir. Respuesta inmediata por WhatsApp, 24/7.
        </p>

        <div class="flex flex-col gap-3 mb-8">
          <a
            href={waLink()}
            target="_blank"
            rel="noopener"
            class="wa-float-pulse inline-flex items-center justify-center gap-2 h-[60px] px-7 rounded-full bg-[color:var(--color-wa)] text-[color:var(--color-ink)] font-bold text-lg shadow-[var(--shadow-cta)] hover:bg-[color:var(--color-wa-dark)] transition-colors w-full sm:w-auto"
            aria-label="Escribir por WhatsApp"
          >
            <Icon name="whatsapp" class="w-6 h-6" />
            Escribir por WhatsApp
          </a>
          <a
            href={site.phoneHref}
            class="inline-flex items-center justify-center gap-2 h-14 px-7 rounded-full border-2 border-white text-white font-bold text-lg hover:bg-white hover:text-[color:var(--color-ink)] transition-colors w-full sm:w-auto"
            aria-label={`Llamar a ${site.name} ${site.phone}`}
          >
            <Icon name="phone-call" class="w-5 h-5" />
            Llamar {site.phone}
          </a>
        </div>

        <div class="flex flex-wrap gap-6 text-[color:var(--color-chrome)]">
          <div class="flex items-center gap-2">
            <Icon name="clock" class="w-5 h-5 text-[color:var(--color-yellow)]" />
            <span>{site.hours}</span>
          </div>
          <a
            href={site.social.instagram}
            target="_blank"
            rel="noopener"
            class="flex items-center gap-2 hover:text-white transition-colors"
          >
            <Icon name="instagram" class="w-5 h-5 text-[color:var(--color-yellow)]" />
            <span>{site.social.instagramHandle}</span>
          </a>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row flex-wrap justify-center lg:justify-end gap-4" data-reveal>
        <div class="bg-white rounded-2xl p-6 shadow-[var(--shadow-brand-lg)] text-center w-full max-w-[280px] sm:w-[260px]">
          <img
            src={withBase("images/qr-whatsapp.jpg")}
            alt="Código QR de WhatsApp de Grúas Sepu"
            width="220"
            height="220"
            class="w-[220px] h-[220px] mx-auto mb-4"
            loading="lazy"
            decoding="async"
          />
          <p class="font-bold text-[color:var(--color-ink)] text-sm">
            Escanea y escríbenos al instante
          </p>
        </div>

        <button
          type="button"
          id="share-card-btn"
          class="bg-white rounded-2xl p-4 shadow-[var(--shadow-brand-lg)] hover:shadow-xl hover:-translate-y-1 transition-all text-center w-full max-w-[280px] sm:w-[260px] flex flex-col justify-center cursor-pointer"
          aria-label="Compartir tarjeta de contacto de Grúas Sepu"
        >
          <Image
            id="tarjeta-card-img"
            src={tarjeta}
            alt="Tarjeta de contacto de Grúas Sepu"
            width={480}
            class="w-full h-auto rounded-lg mb-3 pointer-events-none"
            loading="lazy"
            decoding="async"
          />
          <p class="font-bold text-[color:var(--color-ink)] text-sm">
            Nuestra tarjeta de contacto
          </p>
          <p class="flex items-center justify-center gap-1.5 text-slate-500 text-xs mt-1">
            <Icon name="share" class="w-3.5 h-3.5" />
            Toca para compartir
          </p>
        </button>
      </div>
    </div>
  </div>
</section>

<script>
  const shareBtn = document.getElementById("share-card-btn");
  const cardImg = document.getElementById("tarjeta-card-img") as HTMLImageElement | null;

  shareBtn?.addEventListener("click", async () => {
    if (!cardImg) return;

    const imageUrl = cardImg.currentSrc || cardImg.src;
    const shareData = {
      title: "Grúas Sepu",
      text: "Tarjeta de contacto de Grúas Sepu — Grúa 24/7 en la Región de Ñuble.",
    };

    try {
      if (navigator.canShare) {
        const response = await fetch(imageUrl);
        const blob = await response.blob();
        const file = new File([blob], "tarjeta-gruas-sepu.jpg", { type: blob.type || "image/jpeg" });

        if (navigator.canShare({ files: [file] })) {
          await navigator.share({ ...shareData, files: [file] });
          return;
        }
      }

      if (navigator.share) {
        await navigator.share({ ...shareData, url: imageUrl });
        return;
      }

      // Fallback sin Web Share API (desktop): descarga directa.
      const link = document.createElement("a");
      link.href = imageUrl;
      link.download = "tarjeta-gruas-sepu.jpg";
      document.body.appendChild(link);
      link.click();
      link.remove();
    } catch (err) {
      // El usuario canceló la hoja de compartir, o falló el fetch: no es un error real.
      if (err instanceof Error && err.name !== "AbortError") {
        console.error("No se pudo compartir la tarjeta:", err);
      }
    }
  });
</script>
